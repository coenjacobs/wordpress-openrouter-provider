{
    "name": "coenjacobs/openrouter-provider",
    "description": "OpenRouter AI provider for WordPress AI Client",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "coenjacobs/wordpress-ai-provider": "^0.4.0",
        "lapisense/wordpress-client": "^0.2.0"
    },
    "autoload": {
        "psr-4": {
            "CoenJacobs\\OpenRouterProvider\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpcompatibility/php-compatibility": "^10.1",
        "php-stubs/wordpress-stubs": "^6.9",
        "phpstan/phpstan": "^1.12",
        "phpmd/phpmd": "^2.15",
        "niels-de-blaauw/php-doc-check": "^0.4.0"
    },
    "extra": {
        "mozart": {
            "dep_namespace": "CoenJacobs\\OpenRouterProvider\\Dependencies\\",
            "dep_directory": "/src/Dependencies/",
            "classmap_directory": "/src/Dependencies/classes/",
            "classmap_prefix": "OPENROUTER_DEP_",
            "packages": [
                "coenjacobs/wordpress-ai-provider",
                "lapisense/wordpress-client"
            ],
            "delete_vendor_directories": true
        }
    },
    "scripts": {
        "test": [
            "@test:lint",
            "@test:phpstan",
            "@test:phpmd",
            "@test:docs"
        ],
        "test:lint": [
            "composer validate",
            "./vendor/bin/phpcs --standard=phpcs.xml.dist"
        ],
        "test:phpstan": [
            "./vendor/bin/phpstan analyse -c phpstan.neon.dist --memory-limit=2G"
        ],
        "test:phpmd": [
            "./vendor/bin/phpmd src ansi phpmd.xml.dist --exclude src/Dependencies"
        ],
        "test:docs": [
            "./vendor/bin/php-doc-check src --exclude src/Dependencies"
        ]
    }
}
